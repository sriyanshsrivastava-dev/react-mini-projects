# ==========================================
# 📦 Dependencies (ALL projects)
# ==========================================
node_modules/
**/node_modules/

# ==========================================
# 🚀 Build outputs
# ==========================================
dist/
build/
**/dist/
**/build/

# Vite cache
.vite/
**/.vite/

# ==========================================
# 📝 Logs
# ==========================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================================
# 🔐 Environment files
# ==========================================
.env
.env.*
**/.env
**/.env.*

# ==========================================
# 🖥️ OS files
# ==========================================
.DS_Store
Thumbs.db

# ==========================================
# 💻 IDE / Editor
# ==========================================
.vscode/
.idea/
*.swp
*.swo
*~

# ==========================================
# ⚡ Cache / temp / tooling
# ==========================================
.cache/
**/.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# Framework caches (future-proof)
.next/
.nuxt/
.svelte-kit/

# ==========================================
# 🧪 Testing
# ==========================================
coverage/
**/coverage/

# ==========================================
# 📚 TypeScript
# ==========================================
*.tsbuildinfo

# ==========================================
# 📦 Misc
# ==========================================
*.local
*.tmp
*.temp
*.out

# ==========================================
# 🎨 Tailwind / PostCSS (optional)
# ==========================================
.tailwindcss/
**/.tailwindcss/
.postcss-cache/
**/.postcss-cache/

# ==========================================
# 🔑 Lock files (RECOMMENDED TO KEEP)
# ==========================================
# package-lock.json
# yarn.lock
# pnpm-lock.yaml